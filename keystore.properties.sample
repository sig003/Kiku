# 릴리스 서명 설정 샘플 — 이 파일을 복사해 `keystore.properties`로 저장하고 값을 채운다.
#   cp keystore.properties.sample keystore.properties
#
# ⚠️ 실제 비밀번호는 절대 이 .sample 에 쓰지 말 것! 이 파일은 git에 커밋된다.
# 실제 값은 keystore.properties (git 제외)에만 넣는다. .jks 도 커밋 금지.
# 값은 릴리스 키(.jks)를 keytool로 만들 때 입력한 것과 정확히 일치해야 한다.

# 릴리스 키스토어 파일명 — 프로젝트 루트에 둔 .jks 파일 이름(경로 아님, 파일명만)
storeFile=kiku-release.jks

# 키스토어(스토어) 비밀번호 — keytool 생성 시 입력한 값
storePassword=CHANGE_ME

# 키 별칭 — keytool 의 -alias 값 (이 프로젝트는 kiku 로 생성)
keyAlias=kiku

# 키 비밀번호 — keytool 생성 시 alias 에 준 비밀번호(보통 storePassword 와 동일)
keyPassword=CHANGE_ME
