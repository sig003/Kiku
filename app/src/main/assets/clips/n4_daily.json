{
  "id": 3,
  "category": "N4 생활회화",
  "title": "생활회화 100문장",
  "mode": "DRILL",
  "sentences": [
    { "id": 1, "jp": "今日は朝からいい天気ですね。", "kr": "오늘은 아침부터 날씨가 좋네요.", "words": [ {"jp":"天気","kr":"날씨"} ] },
    { "id": 2, "jp": "午後から雨が降るかもしれません。", "kr": "오후부터 비가 올지도 모릅니다.", "words": [ {"jp":"降る","kr":"내리다"} ] },
    { "id": 3, "jp": "傘を持って行ったほうがいいですよ。", "kr": "우산을 가지고 가는 게 좋아요.", "words": [ {"jp":"傘","kr":"우산"} ] },
    { "id": 4, "jp": "明日は晴れるそうです。", "kr": "내일은 맑을 거라고 합니다.", "words": [ {"jp":"晴れる","kr":"맑다, 개다"} ] },
    { "id": 5, "jp": "最近だんだん寒くなってきましたね。", "kr": "요즘 점점 추워지고 있네요.", "words": [ {"jp":"最近","kr":"최근, 요즘"}, {"jp":"だんだん","kr":"점점"} ] },
    { "id": 6, "jp": "週末に一緒に映画を見に行きませんか。", "kr": "주말에 같이 영화 보러 가지 않을래요?", "words": [ {"jp":"週末","kr":"주말"} ] },
    { "id": 7, "jp": "土曜日の午後なら時間があります。", "kr": "토요일 오후라면 시간이 있어요.", "words": [ {"jp":"午後","kr":"오후"}, {"jp":"～なら","kr":"～라면"} ] },
    { "id": 8, "jp": "何時にどこで会いましょうか。", "kr": "몇 시에 어디서 만날까요?", "words": [ {"jp":"何時","kr":"몇 시"}, {"jp":"会う","kr":"만나다"} ] },
    { "id": 9, "jp": "駅の前で三時に待っています。", "kr": "역 앞에서 3시에 기다리고 있을게요.", "words": [ {"jp":"待つ","kr":"기다리다"} ] },
    { "id": 10, "jp": "約束の時間に遅れてすみません。", "kr": "약속 시간에 늦어서 죄송합니다.", "words": [ {"jp":"約束","kr":"약속"}, {"jp":"遅れる","kr":"늦다"} ] },
    { "id": 11, "jp": "お昼ごはんはもう食べましたか。", "kr": "점심밥은 벌써 먹었어요?", "words": [ {"jp":"お昼ごはん","kr":"점심밥"} ] },
    { "id": 12, "jp": "今日は外で食べましょう。", "kr": "오늘은 밖에서 먹읍시다.", "words": [ {"jp":"外で","kr":"밖에서"}, {"jp":"～ましょう","kr":"～합시다"} ] },
    { "id": 13, "jp": "このお店のラーメンはとてもおいしいです。", "kr": "이 가게의 라면은 아주 맛있어요.", "words": [ {"jp":"お店","kr":"가게"} ] },
    { "id": 14, "jp": "何を注文するか決めましたか。", "kr": "무엇을 주문할지 정했어요?", "words": [ {"jp":"注文する","kr":"주문하다"}, {"jp":"決める","kr":"정하다, 결정하다"} ] },
    { "id": 15, "jp": "私はカレーにします。", "kr": "저는 카레로 할게요.", "words": [ {"jp":"にする","kr":"~로 하다"} ] },
    { "id": 16, "jp": "すみません、お水をもう一杯ください。", "kr": "죄송한데, 물 한 잔 더 주세요.", "words": [ {"jp":"一杯","kr":"한 잔"} ] },
    { "id": 17, "jp": "この料理はちょっと辛すぎます。", "kr": "이 요리는 좀 많이 매워요.", "words": [ {"jp":"辛い","kr":"맵다"}, {"jp":"すぎる","kr":"너무 ~하다"} ] },
    { "id": 18, "jp": "デザートも頼みませんか。", "kr": "디저트도 시키지 않을래요?", "words": [ {"jp":"頼む","kr":"부탁하다, 주문하다"} ] },
    { "id": 19, "jp": "お会計はレジでお願いします。", "kr": "계산은 계산대에서 부탁드려요.", "words": [ {"jp":"会計","kr":"계산"}, {"jp":"レジ","kr":"계산대"} ] },
    { "id": 20, "jp": "今日は私がおごりますよ。", "kr": "오늘은 제가 살게요.", "words": [ {"jp":"おごる","kr":"한턱내다, 사다"} ] },
    { "id": 21, "jp": "私の趣味は音楽を聞くことです。", "kr": "제 취미는 음악을 듣는 것이에요.", "words": [ {"jp":"趣味","kr":"취미"}, {"jp":"聞く","kr":"듣다"} ] },
    { "id": 22, "jp": "子どものころからピアノを習っています。", "kr": "어릴 때부터 피아노를 배우고 있어요.", "words": [ {"jp":"習う","kr":"배우다"} ] },
    { "id": 23, "jp": "週に三回ジムで運動しています。", "kr": "일주일에 세 번 헬스장에서 운동하고 있어요.", "words": [ {"jp":"運動する","kr":"운동하다"} ] },
    { "id": 24, "jp": "私はまだ富士山に登ったことがありません。", "kr": "저는 아직 후지산에 올라간 적이 없어요.", "words": [ {"jp":"登る","kr":"오르다, 등산하다"} ] },
    { "id": 25, "jp": "日本の料理を作ってみたいです。", "kr": "일본 요리를 만들어 보고 싶어요.", "words": [ {"jp":"～てみる","kr":"～해 보다"} ] },
    { "id": 26, "jp": "写真を撮るのが好きです。", "kr": "사진 찍는 것을 좋아해요.", "words": [ {"jp":"撮る","kr":"(사진을) 찍다"} ] },
    { "id": 27, "jp": "週末はたいてい家で本を読みます。", "kr": "주말은 대개 집에서 책을 읽어요.", "words": [ {"jp":"たいてい","kr":"대개, 보통"} ] },
    { "id": 28, "jp": "旅行の計画を立てているところです。", "kr": "여행 계획을 세우고 있는 중이에요.", "words": [ {"jp":"計画","kr":"계획"}, {"jp":"立てる","kr":"세우다"} ] },
    { "id": 29, "jp": "夏休みに海へ行くつもりです。", "kr": "여름방학에 바다에 갈 생각이에요.", "words": [ {"jp":"つもり","kr":"~할 생각"} ] },
    { "id": 30, "jp": "この町には有名なお寺がたくさんあります。", "kr": "이 마을에는 유명한 절이 많이 있어요.", "words": [ {"jp":"有名","kr":"유명함"}, {"jp":"お寺","kr":"절"} ] },
    { "id": 31, "jp": "私の家族は五人です。", "kr": "우리 가족은 다섯 명이에요.", "words": [ {"jp":"家族","kr":"가족"} ] },
    { "id": 32, "jp": "兄は東京の会社で働いています。", "kr": "형은 도쿄 회사에서 일하고 있어요.", "words": [ {"jp":"働く","kr":"일하다"} ] },
    { "id": 33, "jp": "妹は今年大学に入りました。", "kr": "여동생은 올해 대학에 들어갔어요.", "words": [ {"jp":"妹","kr":"여동생"} ] },
    { "id": 34, "jp": "母は料理がとても上手です。", "kr": "어머니는 요리를 아주 잘해요.", "words": [ {"jp":"上手","kr":"잘함, 능숙함"} ] },
    { "id": 35, "jp": "父は毎朝犬と散歩します。", "kr": "아버지는 매일 아침 개와 산책해요.", "words": [ {"jp":"散歩する","kr":"산책하다"} ] },
    { "id": 36, "jp": "友達が私に誕生日のプレゼントをくれました。", "kr": "친구가 나에게 생일 선물을 주었어요.", "words": [ {"jp":"誕生日","kr":"생일"}, {"jp":"くれる","kr":"(나에게) 주다"} ] },
    { "id": 37, "jp": "私は弟に本をあげました。", "kr": "나는 남동생에게 책을 주었어요.", "words": [ {"jp":"弟","kr":"남동생"}, {"jp":"あげる","kr":"주다"} ] },
    { "id": 38, "jp": "先生に日本語を教えてもらいました。", "kr": "선생님에게 일본어를 배웠어요.", "words": [ {"jp":"教える","kr":"가르치다"}, {"jp":"～てもらう","kr":"(남이 나에게) ～해 주다"} ] },
    { "id": 39, "jp": "祖父はもう八十歳になりました。", "kr": "할아버지는 벌써 여든 살이 되셨어요.", "words": [ {"jp":"祖父","kr":"할아버지"} ] },
    { "id": 40, "jp": "家族と一緒に写真を撮りました。", "kr": "가족과 함께 사진을 찍었어요.", "words": [ {"jp":"撮る","kr":"찍다"} ] },
    { "id": 41, "jp": "新しい靴を買いに行きたいです。", "kr": "새 신발을 사러 가고 싶어요.", "words": [ {"jp":"靴","kr":"신발"} ] },
    { "id": 42, "jp": "このシャツはいくらですか。", "kr": "이 셔츠는 얼마예요?", "words": [ {"jp":"シャツ","kr":"셔츠"}, {"jp":"いくら","kr":"얼마"} ] },
    { "id": 43, "jp": "もう少し安いのはありませんか。", "kr": "조금 더 싼 것은 없어요?", "words": [ {"jp":"安い","kr":"싸다"} ] },
    { "id": 44, "jp": "これを試着してもいいですか。", "kr": "이것을 입어 봐도 돼요?", "words": [ {"jp":"試着する","kr":"입어보다"} ] },
    { "id": 45, "jp": "青いのより赤いほうが好きです。", "kr": "파란 것보다 빨간 것이 더 좋아요.", "words": [ {"jp":"～より","kr":"～보다"}, {"jp":"～ほうが","kr":"～쪽이 (더)"} ] },
    { "id": 46, "jp": "カードで払ってもいいですか。", "kr": "카드로 지불해도 돼요?", "words": [ {"jp":"払う","kr":"지불하다"} ] },
    { "id": 47, "jp": "スーパーで牛乳と卵を買わなければなりません。", "kr": "슈퍼에서 우유와 계란을 사야 해요.", "words": [ {"jp":"牛乳","kr":"우유"}, {"jp":"卵","kr":"계란"} ] },
    { "id": 48, "jp": "この店は日曜日も開いています。", "kr": "이 가게는 일요일에도 열려 있어요.", "words": [ {"jp":"開く","kr":"열리다"} ] },
    { "id": 49, "jp": "セールで安くなっていたので、たくさん買いました。", "kr": "세일로 싸져 있어서 많이 샀어요.", "words": [ {"jp":"セール","kr":"세일"} ] },
    { "id": 50, "jp": "袋はいりません、そのままで大丈夫です。", "kr": "봉투는 필요 없어요, 그대로 괜찮아요.", "words": [ {"jp":"袋","kr":"봉투, 봉지"} ] },
    { "id": 51, "jp": "今日はとても疲れました。", "kr": "오늘은 아주 피곤했어요.", "words": [ {"jp":"疲れる","kr":"피곤하다, 지치다"} ] },
    { "id": 52, "jp": "そのニュースを聞いてとても驚きました。", "kr": "그 뉴스를 듣고 매우 놀랐어요.", "words": [ {"jp":"驚く","kr":"놀라다"} ] },
    { "id": 53, "jp": "試験に合格してとてもうれしいです。", "kr": "시험에 합격해서 정말 기뻐요.", "words": [ {"jp":"試験","kr":"시험"}, {"jp":"合格する","kr":"합격하다"} ] },
    { "id": 54, "jp": "明日の発表がちょっと心配です。", "kr": "내일 발표가 좀 걱정돼요.", "words": [ {"jp":"発表","kr":"발표"}, {"jp":"心配","kr":"걱정"} ] },
    { "id": 55, "jp": "一人で暮らすのは少し寂しいです。", "kr": "혼자 사는 것은 조금 외로워요.", "words": [ {"jp":"暮らす","kr":"살다, 생활하다"}, {"jp":"寂しい","kr":"외롭다, 쓸쓸하다"} ] },
    { "id": 56, "jp": "頭が痛いので、早く帰りたいです。", "kr": "머리가 아파서 빨리 집에 가고 싶어요.", "words": [ {"jp":"痛い","kr":"아프다"} ] },
    { "id": 57, "jp": "風邪をひいたみたいです。", "kr": "감기에 걸린 것 같아요.", "words": [ {"jp":"風邪","kr":"감기"}, {"jp":"ひく","kr":"(감기에) 걸리다"} ] },
    { "id": 58, "jp": "熱があるなら、病院へ行ったほうがいいです。", "kr": "열이 있으면 병원에 가는 게 좋아요.", "words": [ {"jp":"熱","kr":"열"}, {"jp":"病院","kr":"병원"} ] },
    { "id": 59, "jp": "薬を飲んで、ゆっくり休んでください。", "kr": "약을 먹고 푹 쉬세요.", "words": [ {"jp":"薬","kr":"약"}, {"jp":"休む","kr":"쉬다"} ] },
    { "id": 60, "jp": "体に気をつけてください。", "kr": "몸조심하세요.", "words": [ {"jp":"気をつける","kr":"조심하다"} ] },
    { "id": 61, "jp": "よかったら、うちに遊びに来ませんか。", "kr": "괜찮으면 우리 집에 놀러 오지 않을래요?", "words": [ {"jp":"遊ぶ","kr":"놀다"} ] },
    { "id": 62, "jp": "今度、みんなで飲みに行きましょう。", "kr": "다음에 다 같이 한잔하러 갑시다.", "words": [ {"jp":"今度","kr":"이번, 다음"}, {"jp":"飲みに行く","kr":"술 마시러 가다, 한잔하러 가다"} ] },
    { "id": 63, "jp": "誕生日パーティーに招待してくれてありがとう。", "kr": "생일 파티에 초대해 줘서 고마워.", "words": [ {"jp":"招待する","kr":"초대하다"} ] },
    { "id": 64, "jp": "残念ですが、その日は都合が悪いです。", "kr": "아쉽지만 그날은 시간이 안 돼요.", "words": [ {"jp":"残念","kr":"아쉬움, 유감"}, {"jp":"都合","kr":"사정, 형편"} ] },
    { "id": 65, "jp": "もし時間があったら、ぜひ来てください。", "kr": "혹시 시간이 있으면 꼭 오세요.", "words": [ {"jp":"もし","kr":"혹시, 만약"}, {"jp":"ぜひ","kr":"꼭, 부디"} ] },
    { "id": 66, "jp": "お久しぶりです、お元気でしたか。", "kr": "오랜만이에요, 잘 지내셨어요?", "words": [ {"jp":"久しぶり","kr":"오랜만"} ] },
    { "id": 67, "jp": "最近仕事はどうですか。", "kr": "요즘 일은 어때요?", "words": [ {"jp":"仕事","kr":"일, 업무"} ] },
    { "id": 68, "jp": "そろそろ帰らなければなりません。", "kr": "슬슬 돌아가야 해요.", "words": [ {"jp":"そろそろ","kr":"슬슬, 이제 곧"} ] },
    { "id": 69, "jp": "また今度ゆっくり話しましょう。", "kr": "다음에 또 천천히 이야기해요.", "words": [ {"jp":"今度","kr":"다음에"}, {"jp":"ゆっくり","kr":"천천히"} ] },
    { "id": 70, "jp": "気をつけて帰ってくださいね。", "kr": "조심해서 돌아가세요.", "words": [ {"jp":"気をつける","kr":"조심하다"} ] },
    { "id": 71, "jp": "毎朝七時に起きて、朝ごはんを食べます。", "kr": "매일 아침 7시에 일어나서 아침을 먹어요.", "words": [ {"jp":"起きる","kr":"일어나다"} ] },
    { "id": 72, "jp": "電車に乗って会社へ行きます。", "kr": "전철을 타고 회사에 가요.", "words": [ {"jp":"電車","kr":"전철"}, {"jp":"乗る","kr":"타다"} ] },
    { "id": 73, "jp": "駅までバスで十分ぐらいかかります。", "kr": "역까지 버스로 10분 정도 걸려요.", "words": [ {"jp":"かかる","kr":"(시간이) 걸리다"} ] },
    { "id": 74, "jp": "この道をまっすぐ行くと、右に銀行があります。", "kr": "이 길을 곧장 가면 오른쪽에 은행이 있어요.", "words": [ {"jp":"まっすぐ","kr":"곧장, 똑바로"}, {"jp":"銀行","kr":"은행"} ] },
    { "id": 75, "jp": "すみません、郵便局はどこですか。", "kr": "실례합니다, 우체국은 어디예요?", "words": [ {"jp":"郵便局","kr":"우체국"} ] },
    { "id": 76, "jp": "次の角を左に曲がってください。", "kr": "다음 모퉁이를 왼쪽으로 도세요.", "words": [ {"jp":"角","kr":"모퉁이"}, {"jp":"曲がる","kr":"돌다, 꺾다"} ] },
    { "id": 77, "jp": "電気を消すのを忘れないでください。", "kr": "불 끄는 것을 잊지 마세요.", "words": [ {"jp":"消す","kr":"끄다"}, {"jp":"忘れる","kr":"잊다"} ] },
    { "id": 78, "jp": "部屋をきれいに掃除しました。", "kr": "방을 깨끗하게 청소했어요.", "words": [ {"jp":"掃除する","kr":"청소하다"} ] },
    { "id": 79, "jp": "洗濯物がまだ乾いていません。", "kr": "빨래가 아직 마르지 않았어요.", "words": [ {"jp":"洗濯物","kr":"빨래"}, {"jp":"乾く","kr":"마르다"} ] },
    { "id": 80, "jp": "夜遅くまで宿題をしていました。", "kr": "밤 늦게까지 숙제를 하고 있었어요.", "words": [ {"jp":"宿題","kr":"숙제"}, {"jp":"遅くまで","kr":"늦게까지"} ] },
    { "id": 81, "jp": "日本語が話せるようになりたいです。", "kr": "일본어를 말할 수 있게 되고 싶어요.", "words": [ {"jp":"ようになる","kr":"~하게 되다"} ] },
    { "id": 82, "jp": "漢字がまだあまり読めません。", "kr": "한자를 아직 별로 못 읽어요.", "words": [ {"jp":"漢字","kr":"한자"}, {"jp":"あまり","kr":"별로, 그다지"} ] },
    { "id": 83, "jp": "毎日少しずつ勉強すれば、上手になります。", "kr": "매일 조금씩 공부하면 잘하게 돼요.", "words": [ {"jp":"上手になる","kr":"잘하게 되다"} ] },
    { "id": 84, "jp": "先週から新しいアルバイトを始めました。", "kr": "지난주부터 새 아르바이트를 시작했어요.", "words": [ {"jp":"アルバイト","kr":"아르바이트"}, {"jp":"始める","kr":"시작하다"} ] },
    { "id": 85, "jp": "この本を借りてもいいですか。", "kr": "이 책을 빌려도 돼요?", "words": [ {"jp":"借りる","kr":"빌리다"} ] },
    { "id": 86, "jp": "宿題を出すのを忘れてしまいました。", "kr": "숙제를 제출하는 것을 잊어버렸어요.", "words": [ {"jp":"出す","kr":"내다, 제출하다"}, {"jp":"しまう","kr":"~해 버리다"} ] },
    { "id": 87, "jp": "明日試験があるので、今夜は勉強します。", "kr": "내일 시험이 있어서 오늘 밤은 공부해요.", "words": [ {"jp":"今夜","kr":"오늘 밤"} ] },
    { "id": 88, "jp": "この単語の意味を教えてください。", "kr": "이 단어의 뜻을 알려 주세요.", "words": [ {"jp":"単語","kr":"단어"}, {"jp":"意味","kr":"의미, 뜻"} ] },
