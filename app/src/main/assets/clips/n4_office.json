{
  "id": 1,
  "category": "N4 회사생활",
  "title": "회사·업무 100문장",
  "mode": "DRILL",
  "sentences": [
    { "id": 1, "jp": "おはようございます、今日もよろしくお願いします。", "kr": "안녕하세요, 오늘도 잘 부탁드립니다.", "words": [ {"jp":"よろしくお願いします","kr":"잘 부탁드립니다"} ] },
    { "id": 2, "jp": "会議は午後三時から始まります。", "kr": "회의는 오후 3시부터 시작됩니다.", "words": [ {"jp":"会議","kr":"회의"}, {"jp":"始まる","kr":"시작되다"} ] },
    { "id": 3, "jp": "この資料をコピーしてください。", "kr": "이 자료를 복사해 주세요.", "words": [ {"jp":"資料","kr":"자료"}, {"jp":"コピー","kr":"복사"} ] },
    { "id": 4, "jp": "部長はまだ会社に来ていません。", "kr": "부장님은 아직 회사에 오지 않았습니다.", "words": [ {"jp":"部長","kr":"부장"}, {"jp":"まだ","kr":"아직"} ] },
    { "id": 5, "jp": "メールを送っておきました。", "kr": "메일을 보내 두었습니다.", "words": [ {"jp":"送る","kr":"보내다"}, {"jp":"～ておく","kr":"～해 두다"} ] },
    { "id": 6, "jp": "すみませんが、少し遅れます。", "kr": "죄송하지만, 조금 늦겠습니다.", "words": [ {"jp":"遅れる","kr":"늦다"} ] },
    { "id": 7, "jp": "この書類にサインをお願いします。", "kr": "이 서류에 서명을 부탁드립니다.", "words": [ {"jp":"書類","kr":"서류"} ] },
    { "id": 8, "jp": "電話が鳴っていますよ。", "kr": "전화가 울리고 있어요.", "words": [ {"jp":"鳴る","kr":"울리다"} ] },
    { "id": 9, "jp": "明日までにこの仕事を終わらせなければなりません。", "kr": "내일까지 이 일을 끝내야 합니다.", "words": [ {"jp":"終わらせる","kr":"끝내다"}, {"jp":"～なければならない","kr":"～해야 한다"} ] },
    { "id": 10, "jp": "会議室はどこですか。", "kr": "회의실은 어디입니까?", "words": [ {"jp":"会議室","kr":"회의실"} ] },
    { "id": 11, "jp": "田中さんに電話をかけてもいいですか。", "kr": "다나카 씨에게 전화를 걸어도 됩니까?", "words": [ {"jp":"電話をかける","kr":"전화를 걸다"} ] },
    { "id": 12, "jp": "この仕事はもう終わりました。", "kr": "이 일은 이미 끝났습니다.", "words": [ {"jp":"もう","kr":"이미, 벌써"} ] },
    { "id": 13, "jp": "課長に報告書を出しました。", "kr": "과장님에게 보고서를 제출했습니다.", "words": [ {"jp":"課長","kr":"과장"}, {"jp":"報告書","kr":"보고서"} ] },
    { "id": 14, "jp": "パソコンの使い方を教えてください。", "kr": "컴퓨터 사용법을 가르쳐 주세요.", "words": [ {"jp":"使い方","kr":"사용법"} ] },
    { "id": 15, "jp": "来週の出張は東京へ行く予定です。", "kr": "다음 주 출장은 도쿄에 갈 예정입니다.", "words": [ {"jp":"出張","kr":"출장"}, {"jp":"予定","kr":"예정"} ] },
    { "id": 16, "jp": "コピー機が壊れてしまいました。", "kr": "복사기가 고장 나 버렸습니다.", "words": [ {"jp":"壊れる","kr":"고장 나다"}, {"jp":"～てしまう","kr":"～해 버리다"} ] },
    { "id": 17, "jp": "昼休みは何時からですか。", "kr": "점심시간은 몇 시부터입니까?", "words": [ {"jp":"昼休み","kr":"점심시간"} ] },
    { "id": 18, "jp": "この件について相談したいことがあります。", "kr": "이 건에 대해 상의하고 싶은 것이 있습니다.", "words": [ {"jp":"件","kr":"건"}, {"jp":"相談する","kr":"상담하다"} ] },
    { "id": 19, "jp": "会社まで電車で三十分かかります。", "kr": "회사까지 전철로 30분 걸립니다.", "words": [ {"jp":"かかる","kr":"걸리다"} ] },
    { "id": 20, "jp": "資料をもう一度確認してください。", "kr": "자료를 한 번 더 확인해 주세요.", "words": [ {"jp":"もう一度","kr":"한 번 더"}, {"jp":"確認する","kr":"확인하다"} ] },
    { "id": 21, "jp": "先輩がコーヒーを買ってくれました。", "kr": "선배가 커피를 사 주었습니다.", "words": [ {"jp":"先輩","kr":"선배"} ] },
    { "id": 22, "jp": "会議の資料はもう準備できていますか。", "kr": "회의 자료는 이미 준비되어 있습니까?", "words": [ {"jp":"準備","kr":"준비"} ] },
    { "id": 23, "jp": "この漢字の読み方が分かりません。", "kr": "이 한자의 읽는 법을 모르겠습니다.", "words": [ {"jp":"漢字","kr":"한자"}, {"jp":"読み方","kr":"읽는 법"} ] },
    { "id": 24, "jp": "お客様がロビーで待っています。", "kr": "손님이 로비에서 기다리고 있습니다.", "words": [ {"jp":"お客様","kr":"손님"} ] },
    { "id": 25, "jp": "この製品は先月より売れています。", "kr": "이 제품은 지난달보다 잘 팔리고 있습니다.", "words": [ {"jp":"製品","kr":"제품"}, {"jp":"売れる","kr":"팔리다"} ] },
    { "id": 26, "jp": "会議に出たことがありますか。", "kr": "회의에 참석한 적이 있습니까?", "words": [ {"jp":"～たことがある","kr":"～한 적이 있다"} ] },
    { "id": 27, "jp": "明日は休みを取るつもりです。", "kr": "내일은 휴가를 낼 생각입니다.", "words": [ {"jp":"休みを取る","kr":"휴가를 내다"}, {"jp":"～つもり","kr":"～할 생각"} ] },
    { "id": 28, "jp": "書類が多すぎて全部読めません。", "kr": "서류가 너무 많아서 전부 읽을 수 없습니다.", "words": [ {"jp":"～すぎる","kr":"너무 ～하다"} ] },
    { "id": 29, "jp": "この仕事は難しいですが、面白いです。", "kr": "이 일은 어렵지만 재미있습니다.", "words": [ {"jp":"難しい","kr":"어렵다"}, {"jp":"面白い","kr":"재미있다"} ] },
    { "id": 30, "jp": "会議の時間を変えてもらえますか。", "kr": "회의 시간을 바꿔 주실 수 있나요?", "words": [ {"jp":"変える","kr":"바꾸다"} ] },
    { "id": 31, "jp": "パスワードを忘れてしまいました。", "kr": "비밀번호를 잊어버렸습니다.", "words": [ {"jp":"～てしまう","kr":"～해 버리다"} ] },
    { "id": 32, "jp": "この書類を三部コピーしてください。", "kr": "이 서류를 세 부 복사해 주세요.", "words": [ {"jp":"書類","kr":"서류"} ] },
    { "id": 33, "jp": "残業をしなければならないかもしれません。", "kr": "야근을 해야 할지도 모릅니다.", "words": [ {"jp":"残業","kr":"야근"}, {"jp":"～かもしれない","kr":"～할지도 모른다"} ] },
    { "id": 34, "jp": "エレベーターは右のほうにあります。", "kr": "엘리베이터는 오른쪽에 있습니다.", "words": [ {"jp":"エレベーター","kr":"엘리베이터"}, {"jp":"右","kr":"오른쪽"} ] },
    { "id": 35, "jp": "会議で何も言えませんでした。", "kr": "회의에서 아무 말도 할 수 없었습니다.", "words": [ {"jp":"何も～ない","kr":"아무것도 ～않다"}, {"jp":"言える","kr":"말할 수 있다"} ] },
    { "id": 36, "jp": "お昼ごはんを一緒に食べませんか。", "kr": "점심을 함께 먹지 않겠습니까?", "words": [ {"jp":"お昼ごはん","kr":"점심"}, {"jp":"一緒に","kr":"함께"} ] },
    { "id": 37, "jp": "この機械の使い方は簡単です。", "kr": "이 기계의 사용법은 간단합니다.", "words": [ {"jp":"機械","kr":"기계"}, {"jp":"簡単","kr":"간단함"} ] },
    { "id": 38, "jp": "スケジュールを確認しておきます。", "kr": "일정을 확인해 두겠습니다.", "words": [ {"jp":"確認する","kr":"확인하다"}, {"jp":"～ておく","kr":"～해 두다"} ] },
    { "id": 39, "jp": "課長が資料を作ってくださいました。", "kr": "과장님이 자료를 만들어 주셨습니다.", "words": [ {"jp":"～てくださる","kr":"～해 주시다"} ] },
    { "id": 40, "jp": "この仕事を手伝ってくれませんか。", "kr": "이 일을 도와주지 않겠습니까?", "words": [ {"jp":"手伝う","kr":"돕다"} ] },
    { "id": 41, "jp": "先週の会議は長すぎました。", "kr": "지난주 회의는 너무 길었습니다.", "words": [ {"jp":"～すぎる","kr":"너무 ～하다"} ] },
    { "id": 42, "jp": "電話番号を教えていただけますか。", "kr": "전화번호를 가르쳐 주실 수 있습니까?", "words": [ {"jp":"～ていただく","kr":"～해 받다"} ] },
    { "id": 43, "jp": "会議が終わったら、電話します。", "kr": "회의가 끝나면 전화하겠습니다.", "words": [ {"jp":"～たら","kr":"～하면"} ] },
    { "id": 44, "jp": "この報告書はいつまでに出せばいいですか。", "kr": "이 보고서는 언제까지 내면 됩니까?", "words": [ {"jp":"報告書","kr":"보고서"}, {"jp":"～ばいい","kr":"～하면 되다"} ] },
    { "id": 45, "jp": "名刺をいただけますか。", "kr": "명함을 주실 수 있습니까?", "words": [ {"jp":"名刺","kr":"명함"}, {"jp":"いただく","kr":"받다"} ] },
    { "id": 46, "jp": "駅に着いたら連絡してください。", "kr": "역에 도착하면 연락해 주세요.", "words": [ {"jp":"着く","kr":"도착하다"}, {"jp":"連絡する","kr":"연락하다"} ] },
    { "id": 47, "jp": "私はまだ日本語で電話するのが苦手です。", "kr": "저는 아직 일본어로 전화하는 것이 서툽니다.", "words": [ {"jp":"苦手","kr":"서툼, 잘 못함"} ] },
    { "id": 48, "jp": "資料をメールで送ってもらいました。", "kr": "자료를 메일로 보내 주셨어요.", "words": [ {"jp":"送る","kr":"보내다"}, {"jp":"～てもらう","kr":"(남이 나에게) ～해 주다"} ] },
    { "id": 49, "jp": "この仕事はもっと早くできると思います。", "kr": "이 일은 더 빨리 할 수 있다고 생각합니다.", "words": [ {"jp":"もっと","kr":"더"} ] },
    { "id": 50, "jp": "会議の前にトイレに行っておきます。", "kr": "회의 전에 화장실에 가 두겠습니다.", "words": [ {"jp":"～ておく","kr":"～해 두다"} ] },
    { "id": 51, "jp": "この字が小さすぎて読めません。", "kr": "이 글자가 너무 작아서 읽을 수 없습니다.", "words": [ {"jp":"～すぎる","kr":"너무 ～하다"} ] },
    { "id": 52, "jp": "明日の朝、九時に会社に来てください。", "kr": "내일 아침 9시에 회사에 와 주세요.", "words": [ {"jp":"朝","kr":"아침"}, {"jp":"～てください","kr":"～해 주세요"} ] },
    { "id": 53, "jp": "この書類にはんこを押してください。", "kr": "이 서류에 도장을 찍어 주세요.", "words": [ {"jp":"はんこ","kr":"도장"}, {"jp":"押す","kr":"누르다, 찍다"} ] },
    { "id": 54, "jp": "会議の内容をノートに書いておきました。", "kr": "회의 내용을 노트에 적어 두었습니다.", "words": [ {"jp":"内容","kr":"내용"}, {"jp":"～ておく","kr":"～해 두다"} ] },
    { "id": 55, "jp": "この仕事に慣れるまで時間がかかります。", "kr": "이 일에 익숙해질 때까지 시간이 걸립니다.", "words": [ {"jp":"慣れる","kr":"익숙해지다"} ] },
    { "id": 56, "jp": "会議室のエアコンをつけてもいいですか。", "kr": "회의실 에어컨을 켜도 됩니까?", "words": [ {"jp":"つける","kr":"켜다"} ] },
    { "id": 57, "jp": "部長に新しいプロジェクトについて説明しました。", "kr": "부장님에게 새 프로젝트에 대해 설명했습니다.", "words": [ {"jp":"説明する","kr":"설명하다"} ] },
    { "id": 58, "jp": "今日は仕事が多くて疲れました。", "kr": "오늘은 일이 많아서 피곤했습니다.", "words": [ {"jp":"疲れる","kr":"피곤하다"} ] },
    { "id": 59, "jp": "この会社で五年間働いています。", "kr": "이 회사에서 5년간 일하고 있습니다.", "words": [ {"jp":"働く","kr":"일하다"} ] },
    { "id": 60, "jp": "もし雨が降ったら、車で行きます。", "kr": "만약 비가 오면 차로 가겠습니다.", "words": [ {"jp":"降る","kr":"내리다"} ] },
    { "id": 61, "jp": "この機械は私にも使えます。", "kr": "이 기계는 저도 사용할 수 있습니다.", "words": [ {"jp":"機械","kr":"기계"} ] },
    { "id": 62, "jp": "会議の後で食事に行きましょう。", "kr": "회의 후에 식사하러 갑시다.", "words": [ {"jp":"食事","kr":"식사"} ] },
    { "id": 63, "jp": "この件について、明日までに返事をください。", "kr": "이 건에 대해 내일까지 답변을 주세요.", "words": [ {"jp":"返事","kr":"답변, 대답"}, {"jp":"～について","kr":"～에 대해"}, {"jp":"～までに","kr":"～까지"} ] },
    { "id": 64, "jp": "私は営業の仕事をしています。", "kr": "저는 영업 일을 하고 있습니다.", "words": [ {"jp":"営業","kr":"영업"} ] },
    { "id": 65, "jp": "資料をもう少し詳しく書いたほうがいいです。", "kr": "자료를 조금 더 자세히 쓰는 편이 좋습니다.", "words": [ {"jp":"詳しい","kr":"자세하다"}, {"jp":"～たほうがいい","kr":"～하는 편이 좋다"} ] },
    { "id": 66, "jp": "電話に出られなくてすみませんでした。", "kr": "전화를 받지 못해 죄송했습니다.", "words": [ {"jp":"電話に出る","kr":"전화를 받다"} ] },
    { "id": 67, "jp": "今週は忙しくて休めません。", "kr": "이번 주는 바빠서 쉴 수 없습니다.", "words": [ {"jp":"忙しい","kr":"바쁘다"}, {"jp":"休める","kr":"쉴 수 있다"} ] },
    { "id": 68, "jp": "会議の日にちが変わりました。", "kr": "회의 날짜가 바뀌었습니다.", "words": [ {"jp":"日にち","kr":"날짜"}, {"jp":"変わる","kr":"바뀌다"} ] },
    { "id": 69, "jp": "お先に失礼します。", "kr": "먼저 실례하겠습니다(먼저 퇴근하겠습니다).", "words": [ {"jp":"お先に","kr":"먼저"}, {"jp":"失礼する","kr":"실례하다"} ] },
    { "id": 70, "jp": "この資料は誰が作りましたか。", "kr": "이 자료는 누가 만들었습니까?", "words": [ {"jp":"資料","kr":"자료"}, {"jp":"誰","kr":"누구"} ] },
    { "id": 71, "jp": "明日の会議に出席できますか。", "kr": "내일 회의에 출석할 수 있습니까?", "words": [ {"jp":"出席","kr":"출석"} ] },
    { "id": 72, "jp": "パソコンが動かなくなりました。", "kr": "컴퓨터가 작동하지 않게 되었습니다.", "words": [ {"jp":"動く","kr":"작동하다, 움직이다"}, {"jp":"～なくなる","kr":"～하지 않게 되다"} ] },
    { "id": 73, "jp": "この仕事を一週間で終わらせたいです。", "kr": "이 일을 일주일 만에 끝내고 싶습니다.", "words": [ {"jp":"終わらせる","kr":"끝내다"} ] },
    { "id": 74, "jp": "会議の資料を印刷しておいてください。", "kr": "회의 자료를 인쇄해 두세요.", "words": [ {"jp":"印刷する","kr":"인쇄하다"}, {"jp":"～ておく","kr":"～해 두다"} ] },
    { "id": 75, "jp": "田中さんは今、席にいません。", "kr": "다나카 씨는 지금 자리에 없습니다.", "words": [ {"jp":"席","kr":"자리"} ] },
    { "id": 76, "jp": "その件については後で話しましょう。", "kr": "그 건에 대해서는 나중에 이야기합시다.", "words": [ {"jp":"件","kr":"건"} ] },
    { "id": 77, "jp": "会社の近くにおいしい店があります。", "kr": "회사 근처에 맛있는 가게가 있습니다.", "words": [ {"jp":"近く","kr":"근처"}, {"jp":"店","kr":"가게"} ] },
    { "id": 78, "jp": "この書類をなくさないように気をつけてください。", "kr": "이 서류를 잃어버리지 않도록 조심하세요.", "words": [ {"jp":"なくす","kr":"잃어버리다"}, {"jp":"気をつける","kr":"조심하다"} ] },
    { "id": 79, "jp": "会議で新しい意見を出しました。", "kr": "회의에서 새로운 의견을 냈습니다.", "words": [ {"jp":"意見","kr":"의견"} ] },
    { "id": 80, "jp": "この仕事は難しすぎます。", "kr": "이 일은 너무 어렵습니다.", "words": [ {"jp":"～すぎる","kr":"너무 ～하다"} ] },
    { "id": 81, "jp": "資料を読めば、すぐに分かります。", "kr": "자료를 읽으면 바로 알 수 있습니다.", "words": [ {"jp":"すぐに","kr":"바로"} ] },
    { "id": 82, "jp": "後輩に仕事を教えてあげました。", "kr": "후배에게 일을 가르쳐 주었습니다.", "words": [ {"jp":"後輩","kr":"후배"} ] },
    { "id": 83, "jp": "来月から新しい部署に移ります。", "kr": "다음 달부터 새로운 부서로 옮깁니다.", "words": [ {"jp":"部署","kr":"부서"}, {"jp":"移る","kr":"옮기다"} ] },
    { "id": 84, "jp": "この電話はどうやって使いますか。", "kr": "이 전화는 어떻게 사용합니까?", "words": [ {"jp":"どうやって","kr":"어떻게"} ] },
    { "id": 85, "jp": "会議に遅れないように早く出ました。", "kr": "회의에 늦지 않도록 일찍 나왔습니다.", "words": [ {"jp":"遅れる","kr":"늦다"}, {"jp":"～ないように","kr":"～하지 않도록"} ] },
