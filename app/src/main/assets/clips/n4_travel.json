{
  "id": 2,
  "category": "N4 여행",
  "title": "여행 100문장",
  "mode": "DRILL",
  "sentences": [
    { "id": 1, "jp": "空港までタクシーで行きたいです。", "kr": "공항까지 택시로 가고 싶어요.", "words": [ {"jp":"空港","kr":"공항"} ] },
    { "id": 2, "jp": "パスポートを見せてください。", "kr": "여권을 보여 주세요.", "words": [ {"jp":"パスポート","kr":"여권"}, {"jp":"見せる","kr":"보여주다"} ] },
    { "id": 3, "jp": "飛行機は何時に出発しますか。", "kr": "비행기는 몇 시에 출발합니까?", "words": [ {"jp":"飛行機","kr":"비행기"}, {"jp":"出発する","kr":"출발하다"} ] },
    { "id": 4, "jp": "荷物はここに置いてもいいですか。", "kr": "짐은 여기에 놓아도 됩니까?", "words": [ {"jp":"荷物","kr":"짐"}, {"jp":"置く","kr":"놓다"} ] },
    { "id": 5, "jp": "チェックインはもう終わりました。", "kr": "체크인은 벌써 끝났어요.", "words": [ {"jp":"チェックイン","kr":"체크인"} ] },
    { "id": 6, "jp": "窓側の席をお願いします。", "kr": "창가 쪽 자리를 부탁합니다.", "words": [ {"jp":"窓側","kr":"창가 쪽"}, {"jp":"席","kr":"자리"} ] },
    { "id": 7, "jp": "この飛行機はソウルに行きますか。", "kr": "이 비행기는 서울에 갑니까?", "words": [ {"jp":"飛行機","kr":"비행기"}, {"jp":"～に行く","kr":"～에 가다"} ] },
    { "id": 8, "jp": "搭乗券をなくしてしまいました。", "kr": "탑승권을 잃어버리고 말았어요.", "words": [ {"jp":"搭乗券","kr":"탑승권"}, {"jp":"なくす","kr":"잃어버리다"} ] },
    { "id": 9, "jp": "入国の目的は観光です。", "kr": "입국 목적은 관광입니다.", "words": [ {"jp":"入国","kr":"입국"}, {"jp":"目的","kr":"목적"}, {"jp":"観光","kr":"관광"} ] },
    { "id": 10, "jp": "何日ぐらい日本に泊まる予定ですか。", "kr": "며칠 정도 일본에 머물 예정입니까?", "words": [ {"jp":"泊まる","kr":"묵다"}, {"jp":"予定","kr":"예정"} ] },
    { "id": 11, "jp": "スーツケースを開けてもいいですか。", "kr": "여행 가방을 열어도 됩니까?", "words": [ {"jp":"スーツケース","kr":"여행 가방"} ] },
    { "id": 12, "jp": "両替はどこでできますか。", "kr": "환전은 어디에서 할 수 있습니까?", "words": [ {"jp":"両替","kr":"환전"} ] },
    { "id": 13, "jp": "駅までの道を教えてください。", "kr": "역까지 가는 길을 가르쳐 주세요.", "words": [ {"jp":"道","kr":"길"} ] },
    { "id": 14, "jp": "まっすぐ行って、右に曲がってください。", "kr": "곧장 가서 오른쪽으로 도세요.", "words": [ {"jp":"まっすぐ","kr":"곧장"}, {"jp":"曲がる","kr":"돌다"} ] },
    { "id": 15, "jp": "この地図の見方が分かりません。", "kr": "이 지도 보는 법을 모르겠어요.", "words": [ {"jp":"地図","kr":"지도"}, {"jp":"見方","kr":"보는 법"} ] },
    { "id": 16, "jp": "この近くに銀行はありますか。", "kr": "이 근처에 은행은 있습니까?", "words": [ {"jp":"銀行","kr":"은행"} ] },
    { "id": 17, "jp": "駅までどのくらいかかりますか。", "kr": "역까지 얼마나 걸립니까?", "words": [ {"jp":"どのくらい","kr":"얼마나"}, {"jp":"かかる","kr":"걸리다"} ] },
    { "id": 18, "jp": "歩いて十分ぐらいです。", "kr": "걸어서 10분 정도입니다.", "words": [ {"jp":"歩く","kr":"걷다"}, {"jp":"～ぐらい","kr":"～정도"} ] },
    { "id": 19, "jp": "次の電車は何番線から出ますか。", "kr": "다음 전철은 몇 번 선에서 출발합니까?", "words": [ {"jp":"何番線","kr":"몇 번 선"} ] },
    { "id": 20, "jp": "この電車は東京駅に停まりますか。", "kr": "이 전철은 도쿄역에 섭니까?", "words": [ {"jp":"停まる","kr":"서다, 정차하다"} ] },
    { "id": 21, "jp": "切符の買い方を教えてもらえますか。", "kr": "표 사는 법을 가르쳐 주실 수 있어요?", "words": [ {"jp":"切符","kr":"표"}, {"jp":"買い方","kr":"사는 법"} ] },
    { "id": 22, "jp": "急いでいるので、急行に乗ります。", "kr": "서두르고 있어서 급행을 탑니다.", "words": [ {"jp":"急ぐ","kr":"서두르다"}, {"jp":"急行","kr":"급행"} ] },
    { "id": 23, "jp": "この電車に乗れば、空港に着きます。", "kr": "이 전철을 타면 공항에 도착합니다.", "words": [ {"jp":"着く","kr":"도착하다"} ] },
    { "id": 24, "jp": "乗り換えの駅を教えてください。", "kr": "환승할 역을 가르쳐 주세요.", "words": [ {"jp":"乗り換え","kr":"환승"} ] },
    { "id": 25, "jp": "電車が遅れているみたいです。", "kr": "전철이 늦어지고 있는 것 같아요.", "words": [ {"jp":"遅れる","kr":"늦어지다"}, {"jp":"みたい","kr":"~인 것 같다"} ] },
    { "id": 26, "jp": "終電は何時ですか。", "kr": "막차는 몇 시입니까?", "words": [ {"jp":"終電","kr":"막차"} ] },
    { "id": 27, "jp": "ホテルまで乗せてもらえますか。", "kr": "호텔까지 태워 주실 수 있어요?", "words": [ {"jp":"乗せる","kr":"태우다"} ] },
    { "id": 28, "jp": "ここで降ろしてください。", "kr": "여기에서 내려 주세요.", "words": [ {"jp":"降ろす","kr":"내려 주다"} ] },
    { "id": 29, "jp": "料金はいくらになりますか。", "kr": "요금은 얼마가 됩니까?", "words": [ {"jp":"料金","kr":"요금"} ] },
    { "id": 30, "jp": "予約した部屋にチェックインしたいです。", "kr": "예약한 방에 체크인하고 싶어요.", "words": [ {"jp":"予約する","kr":"예약하다"} ] },
    { "id": 31, "jp": "朝ご飯は何時から食べられますか。", "kr": "아침밥은 몇 시부터 먹을 수 있습니까?", "words": [ {"jp":"朝ご飯","kr":"아침밥"}, {"jp":"食べられる","kr":"먹을 수 있다"} ] },
    { "id": 32, "jp": "部屋の鍵をなくしてしまいました。", "kr": "방 열쇠를 잃어버리고 말았어요.", "words": [ {"jp":"鍵","kr":"열쇠"}, {"jp":"なくす","kr":"잃어버리다"} ] },
    { "id": 33, "jp": "もう一泊したいのですが。", "kr": "하룻밤 더 묵고 싶은데요.", "words": [ {"jp":"一泊","kr":"1박"} ] },
    { "id": 34, "jp": "荷物を預かってもらえますか。", "kr": "짐을 맡아 주실 수 있어요?", "words": [ {"jp":"荷物","kr":"짐"}, {"jp":"預かる","kr":"맡다"} ] },
    { "id": 35, "jp": "エアコンが動かないので、直してください。", "kr": "에어컨이 작동하지 않으니 고쳐 주세요.", "words": [ {"jp":"動く","kr":"작동하다"}, {"jp":"直す","kr":"고치다"} ] },
    { "id": 36, "jp": "この近くにおいしいレストランはありますか。", "kr": "이 근처에 맛있는 레스토랑은 있습니까?", "words": [ {"jp":"近く","kr":"근처"}, {"jp":"レストラン","kr":"레스토랑"} ] },
    { "id": 37, "jp": "メニューを見せてもらえますか。", "kr": "메뉴를 보여 주실 수 있어요?", "words": [ {"jp":"見せる","kr":"보여주다"} ] },
    { "id": 38, "jp": "この店のおすすめは何ですか。", "kr": "이 가게의 추천 메뉴는 무엇입니까?", "words": [ {"jp":"おすすめ","kr":"추천"} ] },
    { "id": 39, "jp": "辛い物は食べられません。", "kr": "매운 것은 못 먹어요.", "words": [ {"jp":"辛い","kr":"맵다"} ] },
    { "id": 40, "jp": "水をもう一杯ください。", "kr": "물을 한 잔 더 주세요.", "words": [ {"jp":"一杯","kr":"한 잔"} ] },
    { "id": 41, "jp": "注文したものがまだ来ません。", "kr": "주문한 음식이 아직 안 나와요.", "words": [ {"jp":"注文する","kr":"주문하다"} ] },
    { "id": 42, "jp": "お会計をお願いします。", "kr": "계산 부탁합니다.", "words": [ {"jp":"会計","kr":"계산"} ] },
    { "id": 43, "jp": "カードで払ってもいいですか。", "kr": "카드로 지불해도 됩니까?", "words": [ {"jp":"払う","kr":"지불하다"} ] },
    { "id": 44, "jp": "この料理はとてもおいしかったです。", "kr": "이 요리는 아주 맛있었어요.", "words": [ {"jp":"料理","kr":"요리"} ] },
    { "id": 45, "jp": "お土産を買いたいのですが。", "kr": "기념품을 사고 싶은데요.", "words": [ {"jp":"お土産","kr":"기념품"} ] },
    { "id": 46, "jp": "これを三つください。", "kr": "이것을 세 개 주세요.", "words": [ {"jp":"三つ","kr":"세 개"}, {"jp":"～ください","kr":"～주세요"} ] },
    { "id": 47, "jp": "もう少し安くしてもらえますか。", "kr": "조금 더 싸게 해 주실 수 있어요?", "words": [ {"jp":"安くする","kr":"싸게 하다"}, {"jp":"～てもらえますか","kr":"～해 줄 수 있어요?"} ] },
    { "id": 48, "jp": "試着してもいいですか。", "kr": "입어 봐도 됩니까?", "words": [ {"jp":"試着する","kr":"입어보다"} ] },
    { "id": 49, "jp": "もっと大きいサイズはありますか。", "kr": "더 큰 사이즈는 있습니까?", "words": [ {"jp":"もっと","kr":"더"}, {"jp":"サイズ","kr":"사이즈"} ] },
    { "id": 50, "jp": "別々に包んでください。", "kr": "따로따로 포장해 주세요.", "words": [ {"jp":"別々","kr":"따로따로"}, {"jp":"包む","kr":"포장하다"} ] },
    { "id": 51, "jp": "友達にお土産をあげたいです。", "kr": "친구에게 기념품을 주고 싶어요.", "words": [ {"jp":"あげる","kr":"주다"} ] },
    { "id": 52, "jp": "母がこのかばんをくれました。", "kr": "어머니가 이 가방을 주셨어요.", "words": [ {"jp":"くれる","kr":"주다"} ] },
    { "id": 53, "jp": "駅で地図をもらいました。", "kr": "역에서 지도를 받았어요.", "words": [ {"jp":"地図","kr":"지도"}, {"jp":"もらう","kr":"받다"} ] },
    { "id": 54, "jp": "京都に行ったことがありますか。", "kr": "교토에 가 본 적이 있습니까?", "words": [ {"jp":"ことがある","kr":"~한 적이 있다"} ] },
    { "id": 55, "jp": "お寺と神社を見に行きたいです。", "kr": "절과 신사를 보러 가고 싶어요.", "words": [ {"jp":"お寺","kr":"절"}, {"jp":"神社","kr":"신사"} ] },
    { "id": 56, "jp": "ここで写真を撮ってもいいですか。", "kr": "여기서 사진을 찍어도 됩니까?", "words": [ {"jp":"撮る","kr":"찍다"} ] },
    { "id": 57, "jp": "写真を撮ってもらえますか。", "kr": "사진을 찍어 주실 수 있어요?", "words": [ {"jp":"撮る","kr":"찍다"} ] },
    { "id": 58, "jp": "この建物はとても古いです。", "kr": "이 건물은 아주 오래됐어요.", "words": [ {"jp":"建物","kr":"건물"} ] },
    { "id": 59, "jp": "明日は山に登るつもりです。", "kr": "내일은 산에 오를 생각이에요.", "words": [ {"jp":"登る","kr":"오르다"}, {"jp":"つもり","kr":"~할 생각"} ] },
    { "id": 60, "jp": "天気がよければ、海に行きます。", "kr": "날씨가 좋으면 바다에 갑니다.", "words": [ {"jp":"～ば","kr":"～하면"}, {"jp":"海","kr":"바다"} ] },
    { "id": 61, "jp": "雨が降ったら、美術館に行きましょう。", "kr": "비가 오면 미술관에 갑시다.", "words": [ {"jp":"降る","kr":"내리다"}, {"jp":"美術館","kr":"미술관"} ] },
    { "id": 62, "jp": "ここでチケットを買わなければなりません。", "kr": "여기서 티켓을 사야 합니다.", "words": [ {"jp":"なければならない","kr":"~해야 한다"} ] },
    { "id": 63, "jp": "館内では静かにしてください。", "kr": "관내에서는 조용히 해 주세요.", "words": [ {"jp":"館内","kr":"관내"} ] },
    { "id": 64, "jp": "ここに触らないでください。", "kr": "여기에 손대지 마세요.", "words": [ {"jp":"触る","kr":"손대다"}, {"jp":"ないでください","kr":"~하지 마세요"} ] },
    { "id": 65, "jp": "道に迷ってしまいました。", "kr": "길을 잃어버리고 말았어요.", "words": [ {"jp":"迷う","kr":"헤매다"}, {"jp":"しまう","kr":"~해 버리다"} ] },
    { "id": 66, "jp": "財布をどこかに忘れました。", "kr": "지갑을 어딘가에 두고 왔어요.", "words": [ {"jp":"財布","kr":"지갑"} ] },
    { "id": 67, "jp": "助けてもらえませんか。", "kr": "도와주실 수 없나요?", "words": [ {"jp":"助ける","kr":"돕다"} ] },
    { "id": 68, "jp": "パスポートをなくしたので、困っています。", "kr": "여권을 잃어버려서 곤란해요.", "words": [ {"jp":"困る","kr":"곤란하다"} ] },
    { "id": 69, "jp": "近くに交番はありますか。", "kr": "근처에 파출소는 있습니까?", "words": [ {"jp":"交番","kr":"파출소"} ] },
    { "id": 70, "jp": "気分が悪いので、病院に行きたいです。", "kr": "몸이 안 좋아서 병원에 가고 싶어요.", "words": [ {"jp":"気分が悪い","kr":"속이 안 좋다, 몸 상태가 안 좋다"}, {"jp":"病院","kr":"병원"} ] },
    { "id": 71, "jp": "英語が話せる人はいますか。", "kr": "영어를 할 수 있는 사람은 있습니까?", "words": [ {"jp":"話せる","kr":"말할 수 있다"}, {"jp":"英語","kr":"영어"} ] },
    { "id": 72, "jp": "もう一度言ってください。", "kr": "다시 한 번 말해 주세요.", "words": [ {"jp":"もう一度","kr":"다시 한 번"} ] },
    { "id": 73, "jp": "ゆっくり話してもらえますか。", "kr": "천천히 말해 주실 수 있어요?", "words": [ {"jp":"ゆっくり","kr":"천천히"} ] },
    { "id": 74, "jp": "この漢字の読み方が分かりません。", "kr": "이 한자 읽는 법을 모르겠어요.", "words": [ {"jp":"漢字","kr":"한자"}, {"jp":"読み方","kr":"읽는 법"} ] },
    { "id": 75, "jp": "電車の中でお弁当を食べている人がいます。", "kr": "전철 안에서 도시락을 먹고 있는 사람이 있어요.", "words": [ {"jp":"お弁当","kr":"도시락"} ] },
    { "id": 76, "jp": "今、駅で友達を待っています。", "kr": "지금 역에서 친구를 기다리고 있어요.", "words": [ {"jp":"待つ","kr":"기다리다"} ] },
    { "id": 77, "jp": "海の近くのホテルに泊まりたいです。", "kr": "바다 근처의 호텔에 묵고 싶어요.", "words": [ {"jp":"泊まる","kr":"묵다"} ] },
    { "id": 78, "jp": "温泉に入ったことがありません。", "kr": "온천에 들어가 본 적이 없어요.", "words": [ {"jp":"温泉","kr":"온천"}, {"jp":"ことがない","kr":"~한 적이 없다"} ] },
    { "id": 79, "jp": "この電車は次の駅で止まります。", "kr": "이 전철은 다음 역에서 멈춥니다.", "words": [ {"jp":"止まる","kr":"멈추다"} ] },
    { "id": 80, "jp": "バスの時刻表を見せてください。", "kr": "버스 시간표를 보여 주세요.", "words": [ {"jp":"時刻表","kr":"시간표"} ] },
    { "id": 81, "jp": "この席に座ってもいいですか。", "kr": "이 자리에 앉아도 됩니까?", "words": [ {"jp":"席","kr":"자리"}, {"jp":"座る","kr":"앉다"} ] },
    { "id": 82, "jp": "空港でお金を両替しました。", "kr": "공항에서 돈을 환전했어요.", "words": [ {"jp":"両替する","kr":"환전하다"} ] },
    { "id": 83, "jp": "飛行機に乗る前に、荷物を預けます。", "kr": "비행기를 타기 전에 짐을 맡깁니다.", "words": [ {"jp":"預ける","kr":"맡기다"} ] },
    { "id": 84, "jp": "この道をまっすぐ行けば、駅に着きます。", "kr": "이 길을 곧장 가면 역에 도착합니다.", "words": [ {"jp":"まっすぐ","kr":"곧장"}, {"jp":"着く","kr":"도착하다"} ] },
    { "id": 85, "jp": "横断歩道を渡って、左に曲がってください。", "kr": "횡단보도를 건너서 왼쪽으로 도세요.", "words": [ {"jp":"横断歩道","kr":"횡단보도"}, {"jp":"渡る","kr":"건너다"} ] },
    { "id": 86, "jp": "この電車に乗り遅れてしまいました。", "kr": "이 전철을 놓치고 말았어요.", "words": [ {"jp":"乗り遅れる","kr":"놓치다"} ] },
    { "id": 87, "jp": "次のバスは三十分後に来ます。", "kr": "다음 버스는 30분 후에 옵니다.", "words": [ {"jp":"次","kr":"다음"}, {"jp":"～後","kr":"～후"} ] },
    { "id": 88, "jp": "予約をキャンセルしたいのですが。", "kr": "예약을 취소하고 싶은데요.", "words": [ {"jp":"キャンセルする","kr":"취소하다"} ] },
    { "id": 89, "jp": "部屋からきれいな景色が見えます。", "kr": "방에서 예쁜 경치가 보여요.", "words": [ {"jp":"景色","kr":"경치"}, {"jp":"見える","kr":"보이다"} ] },
    { "id": 90, "jp": "電池が切れたので、充電したいです。", "kr": "배터리가 다 돼서 충전하고 싶어요.", "words": [ {"jp":"電池","kr":"배터리"}, {"jp":"切れる","kr":"다 되다"}, {"jp":"充電する","kr":"충전하다"} ] },
    { "id": 91, "jp": "この辺で一番人気のある店はどこですか。", "kr": "이 근처에서 가장 인기 있는 가게는 어디입니까?", "words": [ {"jp":"辺","kr":"근처"}, {"jp":"人気","kr":"인기"} ] },
